    {
      "mode": "data",
      "type": "aws_cloudfront_function",
      "name": "redirect_to_index",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::072351085675:function/RedirectToIndex",
            "code": "function handler(event) {\n    var request = event.request;\n    var uri = request.uri || \"/\";\n\n    // 1) If it's clearly a file (has a dot in the last path segment), pass through.\n    //    e.g. /app.js, /images/logo.png, /assets/app.1234.css, /robots.txt\n    var lastSlash = uri.lastIndexOf(\"/\");\n    var lastSegment = lastSlash \u003e= 0 ? uri.substring(lastSlash + 1) : uri;\n    if (lastSegment.indexOf(\".\") !== -1) {\n        return request;\n    }\n\n    // 2) If it ends with a slash, point to that folder's index.html\n    //    e.g. /docs/  -\u003e /docs/index.html\n    if (uri.endsWith(\"/\")) {\n        request.uri = uri + \"index.html\";\n        return request;\n    }\n\n    // 3) Otherwise, treat it as a client-side route and map to /index.html\n    //    e.g. /dashboard -\u003e /index.html  (URL bar stays /dashboard)\n    request.uri = \"/index.html\";\n    return request;\n}\n",
            "comment": "",
            "etag": "E3UN6WX5RRO2AG",
            "id": "RedirectToIndex",
            "key_value_store_associations": [],
            "last_modified_time": "2025-11-09T04:12:35Z",
